            ]
        },
        {
            "parameters": {
                "jsCode": "// Final result\nreturn {\n  json: {\n    success: true,\n    topics_generated: $input.byIndex[0].json.count || 0,\n    telegram_sent: true,\n    timestamp: new Date().toISOString()\n  }\n};"
            },
            "id": "final-result",
            "name": "Result",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
