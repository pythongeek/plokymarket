{
    "name": "Plokymarket AI Oracle Resolution",
    "nodes": [
        {
            "parameters": {
                "path": "plokymarket-resolution",
                "httpMethod": "POST",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                250,
                300
            ],
            "webhookId": "plokymarket-resolution"
        },
        {
            "parameters": {
                "jsCode": "// Extract market data from webhook payload\nconst marketData = $input.first().json.body || $input.first().json;\n\n// Build keywords from category and question\nconst words = (marketData.question || '').split(' ').filter(w => w.length > 3);\nconst keywords = [\n  marketData.category,\n  ...words.slice(0, 10)\n];\n\n// Bengali and international news sources\nconst bengaliSources = [\n  'prothomalo.com',\n  'bdnews24.com',\n  'banglatribune.com',\n  'thedailystar.net',\n  'somoynews.tv',\n  'dailybangladeshtimes.com'\n];\n\nconst internationalSources = [\n  'bbc.com',\n  'reuters.com',\n  'apnews.com'\n];\n\nreturn {\n  json: {\n    market_id: marketData.market_id,\n    question: marketData.question,\n    category: marketData.category,\n    keywords,\n    sources: [...bengaliSources, ...internationalSources],\n    trigger_source: marketData.trigger_source || 'manual'\n  }\n};"
            },
            "id": "extract-data",
            "name": "Extract Market Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                470,
                300
            ]
        },
        {
            "parameters": {
                "url": "=https://www.googleapis.com/customsearch/v1",
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "key",
                            "value": "={{ $env.GOOGLE_SEARCH_API_KEY }}"
                        },
                        {
                            "name": "cx",
                            "value": "={{ $env.GOOGLE_SEARCH_CX }}"
                        },
                        {
                            "name": "q",
                            "value": "={{ $json.question }} \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6"
                        },
                        {
                            "name": "num",
                            "value": "=5"
                        }
                    ]
                },
                "options": {
                    "retry": {
                        "limit": 3,
                        "statusCodes": "429,500,502,503,504",
                        "errorCodes": "ECONNRESET,ETIMEDOUT,ECONNREFUSED"
                    }
                }
            },
            "id": "google-search-bd",
            "name": "Google Search BD",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                690,
                150
            ]
        },
        {
            "parameters": {
                "url": "=https://www.googleapis.com/customsearch/v1",
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
