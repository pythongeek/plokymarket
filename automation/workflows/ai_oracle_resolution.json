            "typeVersion": 4.2,
            "position": [
                690,
                300
            ]
        },
        {
            "parameters": {
                "url": "=https://newsapi.org/v2/everything",
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "apiKey",
                            "value": "={{ $env.NEWS_API_KEY }}"
                        },
                        {
                            "name": "q",
                            "value": "={{ $json.question }} Bangladesh"
                        },
                        {
                            "name": "sortBy",
                            "value": "=relevancy"
                        },
                        {
                            "name": "pageSize",
                            "value": "=5"
                        },
                        {
                            "name": "language",
                            "value": "=bn"
                        }
                    ]
                },
                "options": {
                    "retry": {
                        "limit": 3,
                        "statusCodes": "429,500,502,503,504",
                        "errorCodes": "ECONNRESET,ETIMEDOUT,ECONNREFUSED"
                    }
                }
            },
            "id": "newsapi-bengali",
            "name": "NewsAPI Bengali",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                690,
                450
            ]
        },
        {
            "parameters": {
                "jsCode": "// Combine all search results\nconst googleBD = $input.byIndex[0].json.items || [];\nconst googleIntl = $input.byIndex[1].json.items || [];\nconst newsBengali = $input.byIndex[2].json.articles || [];\n\n// Deduplicate and format sources\nconst seenUrls = new Set();\nconst sources = [];\n\n// Process Bengali news first (priority)\nfor (const item of googleBD) {\n  if (!seenUrls.has(item.link)) {\n    seenUrls.add(item.link);\n    sources.push({\n      url: item.link,\n      title: item.title,\n      snippet: item.snippet,\n      source: 'google_bd',\n      language: 'bn'\n    });\n  }\n}\n\nfor (const item of newsBengali) {\n  if (!seenUrls.has(item.url)) {\n    seenUrls.add(item.url);\n    sources.push({\n      url: item.url,\n      title: item.title,\n      snippet: item.description,\n      source: 'newsapi',\n      language: 'bn'\n    });\n  }\n}\n\nfor (const item of googleIntl) {\n  if (!seenUrls.has(item.link)) {\n    seenUrls.add(item.link);\n    sources.push({\n      url: item.link,\n      title: item.title,\n      snippet: item.snippet,\n      source: 'google_intl',\n      language: 'en'\n    });\n  }\n}\n\nreturn {\n  json: {\n    ...$input.first().json,\n    sources: sources.slice(0, 10)\n  }\n};"
            },
            "id": "combine-sources",
            "name": "Combine Sources",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                910,
                300
            ]
        },
        {
            "parameters": {
                "model": "={{ $env.GEMINI_MODEL || 'gemini-1.5-flash' }}",
                "options": {},
                "prompt": "=\u0986\u09aa\u09a8\u09bf \u098f\u0995\u099f\u09bf AI Oracle \u09af\u09be \u098f\u0995\u099f\u09bf \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a6\u09cd\u09ac\u09be\u09a3\u09c0 \u09ae\u09be\u09b0\u09cd\u0995\u09c7\u099f \u09aa\u09cd\u09b2\u09cd\u09af\u09be\u099f\u09ab\u09b0\u09cd\u09ae\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0989\u09a4\u09cd\u09a4\u09b0 \u09a8\u09bf\u09b0\u09cd\u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7\u0964\n\n\u09aa\u09cd\u09b0\u09b6\u09cd\u09a8: {{ $json.question }}\n\n\u09b8\u09cb\u09b0\u09cd\u09b8:\n{{ JSON.stringify($json.sources, null, 2) }}\n\n\u09ac\u09bf\u09b6\u09cd\u09b2\u09c7\u09b7\u09a3 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09a8\u09bf\u09b0\u09cd\u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c1\u09a8:\n1. \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09cd\u09af \u0989\u09a4\u09cd\u09a4\u09b0 \u0995\u09c0? (YES \u09ac\u09be NO)\n2. \u0986\u09aa\u09a8\u09be\u09b0 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u09ae\u09be\u09a4\u09cd\u09b0\u09be \u0995\u09a4? (0-100%)\n3. \u09b8\u09cb\u09b0\u09cd\u09b8\u0997\u09c1\u09b2\u09bf\u09b0 \u0989\u09aa\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf \u0995\u09b0\u09c7 \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u09af\u09c1\u0995\u09cd\u09a4\u09bf \u09a6\u09bf\u09a8\n4. \u09b8\u09ac\u099a\u09c7\u09af\u09bc\u09c7 \u09aa\u09cd\u09b0\u09be\u09b8\u0999\u09cd\u0997\u09bf\u0995 \u09b8\u09cb\u09b0\u09cd\u09b8\u0997\u09c1\u09b2\u09bf \u09a4\u09be\u09b2\u09bf\u0995\u09be \u0995\u09b0\u09c1\u09a8\n\n\u098f\u0987 \u09b8\u09a0\u09bf\u0995 JSON \u09ab\u09b0\u09cd\u09ae\u09cd\u09af\u09be\u099f\u09c7 \u0989\u09a4\u09cd\u09a4\u09b0 \u09a6\u09bf\u09a8:\n{\n  \"outcome\": \"YES\" \u09ac\u09be \"NO\" \u09ac\u09be \"UNCERTAIN\",\n  \"confidence_score\": 0-100 \u098f\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09b8\u0982\u0996\u09cd\u09af\u09be,\n  \"reasoning\": \"\u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u09ac\u09cd\u09af\u09be\u0996\u09cd\u09af\u09be \u09ac\u09be\u0982\u09b2\u09be\u09af\u09bc\",\n  \"relevant_sources\": [\"url1\", \"url2\"]\n}"
            },
            "id": "gemini-analysis",
            "name": "Gemini AI Analysis",
            "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
            "typeVersion": 1,
            "position": [
                1130,
                300
            ],
            "credentials": {
                "googlePalmApi": {
                    "id": "gemini-api",
                    "name": "Gemini API"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Parse Gemini response\nconst geminiResponse = $input.first().json.response;\nlet analysis;\n\ntry {\n  // Try to find and parse JSON\n  const jsonMatch = geminiResponse.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    analysis = JSON.parse(jsonMatch[0]);\n  } else {\n    throw new Error('No JSON found');\n  }\n} catch (e) {\n  // Fallback parsing\n  const lowerResp = geminiResponse.toLowerCase();\n  const outcome = lowerResp.includes('\"yes\"') ? 'YES' :\n                  lowerResp.includes('\"no\"') ? 'NO' : 'UNCERTAIN';\n  \n  const confidenceMatch = geminiResponse.match(/(\\d+)\\s*%/);\n  const confidence = confidenceMatch ? parseInt(confidenceMatch[1]) : 50;\n  \n  analysis = {\n    outcome,\n    confidence_score: confidence,\n    reasoning: geminiResponse.substring(0, 500),\n    relevant_sources: []\n  };\n}\n\n// Ensure valid outcome\nif (!['YES', 'NO', 'UNCERTAIN'].includes(analysis.outcome)) {\n  analysis.outcome = 'UNCERTAIN';\n}\n\n// Ensure confidence is 0-100\nanalysis.confidence_score = Math.max(0, Math.min(100, analysis.confidence_score || 50));\n\nreturn {\n  json: {\n    ...$input.first().json,\n    outcome: analysis.outcome,\n    confidence_score: analysis.confidence_score,\n    reasoning: analysis.reasoning,\n    relevant_sources: analysis.relevant_sources || []\n  }\n};"
            },
            "id": "parse-response",
            "name": "Parse AI Response",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1350,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Determine if auto-resolve or manual review\nconst confidence = $input.first().json.confidence_score;\nconst outcome = $input.first().json.outcome;\nconst threshold = 90;\n\nconst canAutoResolve = confidence >= threshold && outcome !== 'UNCERTAIN';\n\nreturn {\n  json: {\n    ...$input.first().json,\n    can_auto_resolve: canAutoResolve,\n    needs_manual_review: !canAutoResolve,\n    resolution_action: canAutoResolve ? 'auto_resolve' : 'manual_review',\n    threshold\n  }\n};"
            },
            "id": "check-confidence",
            "name": "Check Confidence",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1570,
                300
            ]
        },
